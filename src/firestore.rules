
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =====================================================================
    // Helper Functions
    // =====================================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // =====================================================================
    // Admin Full Access Rule
    // =====================================================================
    // Admins have full read/write access to the entire database for management.
    // This rule is checked first. If the user is an admin, access is granted.
    // Subsequent rules define permissions for regular users.
    match /{path=**} {
      allow read, write: if isAdmin();
    }
    
    // =====================================================================
    // User-Specific & Public Rules
    // =====================================================================

    // --- Publicly Readable Collections ---
    // Products, product groups, and carousel images are readable by anyone.
    match /productGroups/{productGroupId} {
      allow read: if true;
    }
    match /products/{productId} {
      allow read: if true;
    }
    match /carouselImages/{imageId} {
      allow read: if true;
    }

    // --- User Profile ---
    // Users can create their own profile.
    // They can read and update their own profile data.
    // Deletion is admin-only (handled by the global admin rule).
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update: if isOwner(userId);
    }
    
    // --- Shopping Cart ---
    // A user's shopping cart and its contents are entirely private.
    match /users/{userId}/shoppingCarts/{cartId}/{cartItems=**} {
      allow read, write, delete: if isOwner(userId);
    }

    // --- Orders ---
    // Users can create and read their own orders.
    // Users can ONLY update an order to cancel it.
    match /users/{userId}/orders/{orderId} {
      allow create: if isOwner(userId);
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.status == 'Cancelado';
    }
  }
}
