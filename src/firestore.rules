
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users can access their own data. Admins can read/update any user data.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn();
    }

    // Product groups are publicly readable. Admins can write.
    match /productGroups/{productGroupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products are publicly readable. Admins can manage them.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Carousel images are publicly readable. Admins can write.
    match /carouselImages/{imageId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Shopping cart and its items are private to the user.
    match /users/{userId}/shoppingCarts/{cartId} {
      allow read, write, delete: if isOwner(userId);
    }
    
    match /users/{userId}/shoppingCarts/{cartId}/cartItems/{itemId} {
      allow read, write, delete: if isOwner(userId);
    }

    // Orders are private to the user, but readable/updatable by admins.
    // Users can create their own orders.
    // Users can update their own orders only to change the status to 'Cancelado'.
    // Admins can read and update any order.
    match /users/{userId}/orders/{orderId} {
      allow create: if isOwner(userId);
      allow read: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.status == 'Cancelado') || isAdmin();
    }
  }
}
